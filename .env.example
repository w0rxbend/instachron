# Instachron environment example.
# Copy to .env for Docker Compose, or source it before local go run commands.

# Host ports used by docker-compose.yml.
TCP_PORT=5000
API_PORT=8080
RESTREAMER_PORT=8090
ENHANCER_PORT=8091
UPSCALER_PORT=8092

# Shared IPC socket. For Docker Compose this is set inside containers.
# For local runs, use a path that all local services can access.
IPC_SOCKET_PATH=/tmp/instachron/frames.sock

# tcp-camera-backend
TCP_ADDR=0.0.0.0:5000
MAX_FRAME_BYTES=5242880
READ_TIMEOUT=30s

# camera-web-api
HTTP_ADDR=:8080
WEB_DIR=./web
CAMERA_CONFIG=./cameras.json

# Restream services
ORIGIN_URL=http://localhost:8080

# camera-web-restream-enhancer-api
SHARPEN=1.0
DARK_THRESHOLD=0.35
BRIGHTNESS_MAX=30.0
CONTRAST_MAX=25.0
JPEG_QUALITY=85

# camera-web-restream-upscaler-api
UPSCALER_JPEG_QUALITY=85
UPSCALER_WORKERS=
UPSCALE_FACTOR=2
QUEUE_MULTIPLIER=1
MAX_INPUT_WIDTH=640
MAX_INPUT_HEIGHT=360
METRICS_INTERVAL_SEC=60

# ffmpeg-streamer
# Exactly one destination must be set: STREAM_URL, RTMP_URL, TWITCH_STREAM_KEY,
# or YOUTUBE_STREAM_KEY. A local RTMP endpoint is useful for smoke tests.
STREAM_URL=rtmp://localhost/live/instachron
RTMP_URL=
TWITCH_STREAM_KEY=
YOUTUBE_STREAM_KEY=
CAMERA_ID=0
MERGE_ALL=false
FFMPEG_PATH=ffmpeg
STREAM_FRAME_RATE=10
FFMPEG_RESTART_DELAY=5s
CELL_WIDTH=320
CELL_HEIGHT=240
